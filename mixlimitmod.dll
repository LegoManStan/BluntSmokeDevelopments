using HarmonyLib;
using MelonLoader;
using Il2CppScheduleOne.ObjectScripts;
using Il2CppScheduleOne.UI.Stations;
using Il2CppScheduleOne.NPCs.Behaviour;

[assembly: MelonInfo(typeof(Mixlimitmod.Core), "Mix Limit Mod", "1.0.0", "BluntSmoker6900")]
[assembly: MelonGame("TVGS", "Schedule I")]

namespace Mixlimitmod
{
    public class Core : MelonMod
    {
        public static MelonPreferences_Category ConfigCategory;
        public static MelonPreferences_Entry<int> PlayerMaxMixQuantity;
        public static MelonPreferences_Entry<int> NpcMaxMixQuantity;

        public override void OnInitializeMelon()
        {
            MelonLogger.Msg("Mix Limit Mod loaded");

            ConfigCategory = MelonPreferences.CreateCategory("MixLimitMod", "Mix Limit Mod");
            ConfigCategory.SetFilePath("UserData/MixLimitMod.cfg");

            PlayerMaxMixQuantity = ConfigCategory.CreateEntry(
                "PlayerMaxMixQuantity",
                1000,
                "Player Max Mix Quantity",
                "Maximum quantity the player can mix at once."
            );

            NpcMaxMixQuantity = ConfigCategory.CreateEntry(
                "NpcMaxMixQuantity",
                1000,
                "NPC Max Mix Quantity",
                "Maximum quantity NPCs can mix at once."
            );

            ConfigCategory.SaveToFile(false);

            MelonLogger.Msg("Config loaded");
            MelonLogger.Msg("PlayerMaxMixQuantity = " + PlayerMaxMixQuantity.Value);
            MelonLogger.Msg("NpcMaxMixQuantity = " + NpcMaxMixQuantity.Value);
        }
    }

    [HarmonyPatch(typeof(MixingStationCanvas), "BeginButtonPressed")]
    internal static class Patch_PlayerMixAmount
    {
        private static void Prefix(MixingStationCanvas __instance)
        {
            try
            {
                MixingStation station = __instance != null ? __instance.MixingStation : null;
                if (station != null)
                {
                    MelonLogger.Msg("[Player] Before MaxMixQuantity = " + station.MaxMixQuantity);
                    station.MaxMixQuantity = Core.PlayerMaxMixQuantity.Value;
                    MelonLogger.Msg("[Player] After MaxMixQuantity = " + station.MaxMixQuantity);
                }
            }
            catch (System.Exception ex)
            {
                MelonLogger.Error("[Player] Prefix error: " + ex);
            }
        }
    }

    [HarmonyPatch(typeof(StartMixingStationBehaviour), "RpcLogic___StartCook_2166136261")]
    internal static class Patch_NpcMixAmount
    {
        private static void Prefix(StartMixingStationBehaviour __instance)
        {
            try
            {
                MixingStation station = __instance != null ? __instance.targetStation : null;
                if (station != null)
                {
                    MelonLogger.Msg("[NPC] Before MaxMixQuantity = " + station.MaxMixQuantity);
                    station.MaxMixQuantity = Core.NpcMaxMixQuantity.Value;
                    MelonLogger.Msg("[NPC] After MaxMixQuantity = " + station.MaxMixQuantity);
                }
            }
            catch (System.Exception ex)
            {
                MelonLogger.Error("[NPC] Prefix error: " + ex);
            }
        }
    }
}
